# YouTube Automation Environment Variables
# Copy this to .env and fill in your own values

# Gemini API (for script generation)
# Get free tier key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Reddit API (for sourcing content)
# Create app: https://www.reddit.com/prefs/apps (choose "script")
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_secret_here
REDDIT_USER_AGENT=youtube-automation/1.0 (include this format for Reddit API)

# YouTube API (for uploading videos)
# Enable in Google Cloud Console: https://console.cloud.google.com
# Create OAuth 2.0 credentials (Desktop application)
# For automated uploads, you'll need OAuth token (generated on first run)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_secret_here

# Optional: Video settings
# Video format: "reddit", "horror", "motivational", "history"
VIDEO_FORMAT=reddit

# Content type: "aita", "relationship", "paranormal", "motivation"
VIDEO_CONTENT_TYPE=aita

# Output resolution: "1080x1920" (Shorts) or "1920x1080" (long-form)
VIDEO_RESOLUTION=1080x1920

# Output duration in seconds: 30 for Shorts, 300-600 for long-form
VIDEO_DURATION=30

# Optional: Custom voice for narration
# Options: en-US-AriaNeural (warm), en-GB-SoniaNeural (authoritative), en-US-GuyNeural (dramatic)
VOICE_NAME=en-US-AriaNeural

# Optional: Voice rate adjustment
# Options: "+10%", "+15%", "+20%" for faster, "-5%" for slower
VOICE_RATE=+10%

# Optional: Enable verbose logging
DEBUG=false
