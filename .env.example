# ─────────────────────────────────────────────────────────────
#  YouTube Automation — Environment Configuration
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────

# Gemini API (script generation + SEO metadata)
# Free tier: 60 req/min, 1M tokens/day
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube OAuth 2.0 (video upload)
# Setup: https://console.cloud.google.com
#   1. New project → Enable "YouTube Data API v3"
#   2. Credentials → OAuth 2.0 Client ID → Desktop application
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# ── RECOMMENDED ───────────────────────────────────────────────

# Pexels API (dark cinematic stock footage + thumbnail backgrounds)
# Free: 200 req/hr, 20K/month — https://www.pexels.com/api/new-key/
# Without this: falls back to animated horror gradient (still cinematic)
PEXELS_API_KEY=your_pexels_api_key_here

# ── OPTIONAL ──────────────────────────────────────────────────

# Reddit API (source real Reddit posts as story material)
# Create: https://www.reddit.com/prefs/apps (choose "script" type)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_secret_here
REDDIT_USER_AGENT=youtube-automation/1.0
